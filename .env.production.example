# Copy to .env on local and VPS, then fill the same values in both places.
# Do not commit real .env files.

# Normal Gateway token. Final/main replies use this token and default to Claude 4.8.
OMBRE_GATEWAY_TOKEN=

# Gemini Gateway token. Relay coordinator/tool loop uses this token and defaults to Gemini 3.5.
OMBRE_GATEWAY_GEMINI_TOKEN=

# Upstream provider keys referenced by config.yaml gateway.upstreams.
OMBRE_GATEWAY_ANTHROPIC_API_KEY=
OMBRE_GATEWAY_GEMINI_API_KEY=

# Relay-side mapping. These are Cloudflare Worker secrets, not Ombre container env vars.
# AGENT_FINAL_API_URL=https://gateway.btombre.men/v1
# AGENT_FINAL_API_KEY=<same value as OMBRE_GATEWAY_TOKEN>
# AGENT_FINAL_MODEL=claude-opus-4-8
# AGENT_FINAL_API_TYPE=openai
# AGENT_FINAL_OMBRE_SESSION_ID=main
# AGENT_COORDINATOR_BASE_URL=https://gateway.btombre.men/v1beta
# AGENT_COORDINATOR_API_KEY=<same value as OMBRE_GATEWAY_GEMINI_TOKEN>
# AGENT_COORDINATOR_AUTH_TYPE=bearer
# AGENT_COORDINATOR_MODEL=gemini-3.5-flash
# AGENT_COORDINATOR_SESSION_ID=relay-coordinator
